### VARIABILI
set $bg             #000000
set $fg             #e5e5e5
set $fg_sec         #777777
set $urgent         #ff4444
set $font           DejaVu Sans Mono 10

set $mod Mod4

set $terminal alacritty
set $fileManager thunar
set $browser librewolf
set $menu dmenu_run -b -fn "$font" -nb "$bg" -sb "$bg" -p "$"

### AUTOSTART APPLICATIONS
exec --no-startup-id xset s off
exec --no-startup-id xset s noblank
exec --no-startup-id xset -dpms

### DISPLAY OUTPUTS
# exec --no-startup-id xrandr --output <monitor> --mode <rend_ex:1920x1080> --rate <hz> --pos <pos_ex:0x0>

### APPEARANCE SETTINGS
default_border pixel 0
default_floating_border pixel 0

gaps inner 0
gaps outer 0

font pango: $font

bar {
    position top
    separator_symbol " "
    status_command i3status
    tray_output DisplayPort-1
    mode dock

    colors {
        background $bg
        statusline $fg
        separator  $fg_sec

        focused_workspace  $bg $bg $fg
        active_workspace   $bg $bg $fg_sec
        inactive_workspace $bg $bg $fg_sec
        urgent_workspace   $bg $bg $urgent
    }
}

### KEYBINDINGS - APPLICATIONS AND SYSTEM
bindsym $mod+Shift+c    reload
bindsym $mod+Shift+f    fullscreen toggle
bindsym $mod+v          floating toggle
bindsym $mod+c          kill
bindsym $mod+q          exec --no-startup-id $terminal
bindsym $mod+f          exec --no-startup-id $fileManager
bindsym $mod+r          exec --no-startup-id $menu
bindsym $mod+b          exec --no-startup-id $browser
bindsym Print           exec --no-startup-id bash -c 'maim -s | swappy -f -' 

### KEYBINDINGS - FOCUS CONTROL
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

### KEYBINDINGS - WORKSPACE SWITCHING
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9

### KEYBINDINGS - MOVE TO WORKSPACE
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9

### KEYBINDINGS - MOVE WINDOW POSITION
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

### RESIZE MODE
bindsym $mod+Shift+r mode "resize"

mode "resize" {
    bindsym h resize shrink width 50 px
    bindsym l resize grow   width 50 px
    bindsym k resize shrink height 50 px
    bindsym j resize grow   height 50 px

    bindsym Escape mode "default"
    bindsym Return mode "default"
}

floating_modifier $mod

### MEDIA CONTROLS
bindsym XF86AudioRaiseVolume    exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume    exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute           exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute        exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

bindsym XF86MonBrightnessUp     exec --no-startup-id brightnessctl s 10%+
bindsym XF86MonBrightnessDown   exec --no-startup-id brightnessctl s 10%-

bindsym XF86AudioNext           exec --no-startup-id playerctl next
bindsym XF86AudioPause          exec --no-startup-id playerctl play-pause
bindsym XF86AudioPlay           exec --no-startup-id playerctl play-pause
bindsym XF86AudioPrev           exec --no-startup-id playerctl previous

### EXIT SESSION
bindsym $mod+Shift+e exit
